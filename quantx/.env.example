# ── Server ──────────────────────────────
NODE_ENV=development
PORT=4000

# Zerodha Kite Connect (replace with real keys)
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret
KITE_ACCESS_TOKEN=your_access_token

# NSE/BSE data provider
MARKET_DATA_PROVIDER=mock         # mock | kite | alphavantage
ALPHAVANTAGE_API_KEY=your_key

# ── Live Price API (Twelve Data) ─────────
# Free tier: 800 req/day, 8 req/min
# Get a free key at https://twelvedata.com/register
# Leave blank to use the built-in mock simulator (works without any key)
TWELVE_DATA_API_KEY=

# Auth
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Redis (optional — for WebSocket session caching)
REDIS_URL=redis://localhost:6379

# ── Client ──────────────────────────────
VITE_API_BASE_URL=http://localhost:4000/api
VITE_WS_URL=ws://localhost:4000
